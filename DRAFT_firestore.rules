rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // For this portfolio, we define the admin by their UID or email.
      // Since we don't have a specific admin UID yet, we'll placeholder it.
      // In a real app, I'd check a /admins/ collection.
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Message Validation
    function isValidMessage(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 100 &&
             data.email.matches('^[^@]+@[^@]+\\.[^@]+$') &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 5000 &&
             data.createdAt == request.time;
    }

    match /messages/{messageId} {
      allow create: if isValidId(messageId) && isValidMessage(incoming());
      allow read, update, delete: if isAdmin();
    }
    
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      // Admins are created manually in the console for security.
    }
  }
}
