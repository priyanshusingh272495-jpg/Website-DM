rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /certifications/{docId=**} {
      allow read, write: if true;
    }
    match /profile/{docId=**} {
      allow read, write: if true;
    }
    match /messages/{docId=**} {
      allow read, write: if true;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
