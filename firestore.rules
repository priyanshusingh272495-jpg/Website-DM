rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email == "priyanshusingh272495@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Message Validation
    function isValidMessage(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 100 &&
             data.email.matches('^[^@]+@[^@]+\\.[^@]+$') &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 5000 &&
             data.createdAt == request.time;
    }

    // Collection Rules
    match /profile/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /certifications/{certId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /messages/{messageId} {
      allow create: if isValidId(messageId) && isValidMessage(incoming());
      allow read, update, delete: if isAdmin();
    }
    
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
