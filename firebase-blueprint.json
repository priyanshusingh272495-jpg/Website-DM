{
  "entities": {
    "Message": {
      "title": "Contact Message",
      "description": "Messages sent through the contact form.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the sender"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email of the sender"
        },
        "message": {
          "type": "string",
          "description": "The message content"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the message was sent"
        }
      },
      "required": ["name", "email", "message", "createdAt"]
    },
    "Profile": {
      "title": "User Profile",
      "description": "Global profile data including the profile image.",
      "type": "object",
      "properties": {
        "imageUrl": {
          "type": "string",
          "description": "Base64 encoded image or URL"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last update timestamp"
        }
      },
      "required": ["imageUrl", "updatedAt"]
    },
    "Certification": {
      "title": "Certification",
      "description": "Details about a professional certification",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "issuer": { "type": "string" },
        "date": { "type": "string" },
        "imageUrl": { "type": "string" },
        "link": { "type": "string" }
      },
      "required": ["title", "issuer", "date", "imageUrl"]
    }
  },
  "firestore": {
    "messages/{messageId}": {
      "schema": "Message",
      "description": "Collection of contact messages"
    },
    "profile/main": {
      "schema": "Profile",
      "description": "The main portfolio profile data"
    },
    "certifications/{certId}": {
      "schema": "Certification",
      "description": "Collection of certifications"
    }
  }
}
