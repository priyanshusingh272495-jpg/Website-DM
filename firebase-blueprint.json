{
  "entities": {
    "Message": {
      "title": "Contact Message",
      "description": "Messages sent through the contact form.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the sender"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email of the sender"
        },
        "message": {
          "type": "string",
          "description": "The message content"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the message was sent"
        }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "messages/{messageId}": {
      "schema": "Message",
      "description": "Collection of contact messages"
    }
  }
}
